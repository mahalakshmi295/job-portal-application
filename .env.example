# =====================================================
# JOB PORTAL APPLICATION - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git (it contains credentials)

# =====================================================
# REQUIRED: Email Configuration (for OTP Feature)
# =====================================================
# 1. Enable 2-Factor Authentication: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password (with spaces)
# 4. Use that password below (NOT your Gmail password!)

MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# =====================================================
# REQUIRED: JWT Configuration (for Authentication)
# =====================================================
# Generate a secure secret key - must be at least 32 characters!
# Use: https://generate-random.org/ or similar tool
# Example: aB3$mK9@nL2#pQ5&rS8!tU1%vW4^xY6*zZ0(aB)cD-eF_gH

JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long_string
JWT_EXPIRATION_MS=86400000

# =====================================================
# OPTIONAL: Job Search API (RapidAPI - JSearch)
# =====================================================
# Free tier: 5,000 requests/month
# Get your key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Without this: Mock job data will be used

RAPIDAPI_KEY=your_rapidapi_key_here

# =====================================================
# OPTIONAL: AI Chatbot (OpenAI GPT-3.5)
# =====================================================
# Free tier: $5 credit for new accounts
# Get your key: https://platform.openai.com/api-keys
# Without this: Rule-based chatbot will be used

OPENAI_API_KEY=sk-your_openai_key_here

# =====================================================
# OPTIONAL: Resume Parser (Affinda API)
# =====================================================
# Free tier: 100 resumes/month
# Get your token: https://www.affinda.com/
# Without this: Regex-based resume parsing will be used

AFFINDA_API_TOKEN=your_affinda_token_here

# =====================================================
# OPTIONAL: Database Configuration
# =====================================================
# Default: H2 in-memory database (file-based if using MongoDB)
# For production: Use PostgreSQL or MongoDB

MONGODB_URI=mongodb://localhost:27017/jobportal
MONGODB_DATABASE=jobportal

# =====================================================
# OPTIONAL: CORS Configuration (Frontend URL)
# =====================================================
# Set to your frontend URL
# Default: http://localhost:3000 (local development)

ALLOWED_ORIGINS=http://localhost:3000

# =====================================================
# OPTIONAL: Application Environment
# =====================================================
# Values: development, staging, production

ENVIRONMENT=development
