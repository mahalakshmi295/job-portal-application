# Job Portal Backend - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ============================================
# DATABASE CONFIGURATION (MongoDB)
# ============================================
MONGODB_URI=mongodb://localhost:27017/jobportal
MONGODB_DATABASE=jobportal

# ============================================
# EMAIL CONFIGURATION (for OTP)
# ============================================
# For Gmail:
# 1. Go to Google Account → Security → 2-Step Verification
# 2. Click "App passwords" -> Generate new app password for "Mail"
# 3. Use the 16-character password below

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# For other email providers:
# - Outlook/Hotmail: smtp.office365.com (port 587)
# - Yahoo: smtp.mail.yahoo.com (port 587)
# - Custom SMTP: Use your provider's SMTP settings

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a secure random string (at least 256 bits / 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-key-min-32-characters-long
JWT_EXPIRATION_MS=86400000

# ============================================
# EXTERNAL API KEYS
# ============================================

# RapidAPI (Job Search via JSearch API)
# Get your key from: https://rapidapi.com/
# Subscribe to: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 5,000 requests/month
RAPIDAPI_KEY=your-rapidapi-key-here

# OpenAI API (AI-Enhanced Chatbot)
# Get your key from: https://platform.openai.com/api-keys
# Free tier: $5 credit for new accounts
# Model used: gpt-3.5-turbo (~$0.002 per 1K tokens)
OPENAI_API_KEY=your-openai-api-key-here

# Affinda API (Resume Parser)
# Get your token from: https://www.affinda.com/
# Free tier: 100 resumes/month
AFFINDA_API_TOKEN=your-affinda-api-token-here

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: Add your production frontend URL
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================
# APPLICATION ENVIRONMENT
# ============================================
# Set to "production" in production, "development" for local dev
ENVIRONMENT=development

# ============================================
# H2 CONSOLE (Development Only)
# ============================================
# Only enable in development, NEVER in production
# Note: With MongoDB, H2 is not used
H2_CONSOLE_ENABLED=false
